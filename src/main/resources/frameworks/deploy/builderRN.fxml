<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="722.0" prefWidth="1100.0" styleClass="mainFxmlClass" stylesheets="@../../styles/builderrn.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="deploy.BuilderRNController">

    <children>

        <!-- HEADER -->
        <Label layoutX="40" layoutY="30" styleClass="title-label" text="Build React Native" />

        <Label layoutX="40" layoutY="70" prefWidth="600" styleClass="description-label" text="Configura la ruta Android, ejecuta builds y controla manualmente la limpieza del proyecto." />

        <!-- PATH -->
        <Label layoutX="40" layoutY="120" styleClass="section-label" text="Ruta Android" />

        <TextField fx:id="androidPathField" layoutX="40" layoutY="150" prefHeight="40" prefWidth="500" />

        <Button layoutX="40" layoutY="206" onAction="#onSaveAndroid" prefHeight="40" prefWidth="120" styleClass="button-save" text="Guardar" />

        <Button layoutX="170" layoutY="206" onAction="#onUnlockAndroid" prefHeight="40" prefWidth="130" styleClass="button-unlock" text="Desbloquear" />

        <Button layoutX="310" layoutY="206" onAction="#onBrowseAndroid" prefHeight="40" prefWidth="120" styleClass="button-primary" text="Buscar" />

        <!-- LIMPIEZA -->
        <Label layoutX="40" layoutY="270" styleClass="section-label" text="Limpieza del proyecto" />

        <Button layoutX="40" layoutY="300" onAction="#onCleanGradle" prefHeight="40" prefWidth="200" styleClass="button-warning" text="Gradle Clean" />

        <Button layoutX="40" layoutY="350" onAction="#onDeleteNodeModules" prefHeight="40" prefWidth="200" styleClass="button-danger" text="Borrar node_modules" />

        <Button layoutX="40" layoutY="400" onAction="#onNpmInstall" prefHeight="40" prefWidth="200" styleClass="button-primary" text="npm install" />

        <!-- STATUS LIMPIEZA -->
        <Label layoutX="40" layoutY="450" styleClass="section-label" text="Estado operaciones" />

        <Label fx:id="operationsStatus" layoutX="40" layoutY="480" styleClass="status-label" text="Estado: -" />

        <!-- BUILD -->
        <Label layoutX="40" layoutY="520" styleClass="section-label" text="Constructor APK" />

        <Button layoutX="40" layoutY="550" onAction="#onBuildAndroid" prefHeight="45" prefWidth="180" styleClass="button-success" text="Build APK Android" />

        <Button fx:id="openAndroidButton" layoutX="230" layoutY="550" onAction="#onOpenAndroidFolder" prefHeight="45" prefWidth="100" styleClass="button-secondary" text="Abrir" />

        <!-- STATUS BUILD -->
        <Label fx:id="buildStatus" layoutX="40" layoutY="605" styleClass="status-label" text="Estado: -" />

        <!-- LOG -->
        <Label layoutX="600" layoutY="30" styleClass="title-log" text="Console log" />

        <Button layoutX="600" layoutY="60" onAction="#onCopyLog" prefHeight="35" prefWidth="120" styleClass="button-primary" text="Copiar" />

        <Button layoutX="730" layoutY="60" onAction="#onClearLog" prefHeight="35" prefWidth="120" styleClass="button-secondary" text="Limpiar" />

        <TextArea fx:id="logArea" editable="false" layoutX="600" layoutY="110" prefHeight="510" prefWidth="450" styleClass="console" wrapText="true" />

        <!-- ================= FOOTER ================= -->

        <!-- 🔥 Separator alineado con contenido -->
        <Separator layoutX="40" layoutY="635" prefWidth="1020" />

        <!-- 🔥 Botón centrado correctamente -->
        <Button layoutX="475" layoutY="655" onAction="#onClose" prefHeight="45" prefWidth="150" styleClass="button-danger" text="Cerrar" />

    </children>

</AnchorPane>
