<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="deployRoot" prefHeight="518.0" prefWidth="600" stylesheets="@../../styles/deployglobal.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="deploy.DeployGlobalController">

    <children>

        <!-- TITLE -->
        <Label layoutX="226.0" layoutY="73.0" styleClass="title-label" text="Deploy Tool" />

        <!-- DESCRIPTION -->
        <Label alignment="CENTER" layoutX="100.0" layoutY="137.0" prefWidth="400" styleClass="section-label" text="Selecciona el tipo de servicio que quieres ejecutar" textAlignment="CENTER" wrapText="true" />

        <!-- REACT NATIVE -->
        <Button fx:id="reactNativeBtn" layoutX="100.0" layoutY="190.0" onAction="#openReactNativeView" prefHeight="60" prefWidth="400" styleClass="button-primary" text="React Native" />

        <!-- WEB / API -->
        <Button fx:id="webDynamicBtn" layoutX="101.0" layoutY="287.0" onAction="#openWebDynamicView" prefHeight="60" prefWidth="400" styleClass="button-success" text="Web / API" />

        <!-- ================= FOOTER ================= -->

        <!-- 🔥 Separator -->
        <Separator layoutX="20" layoutY="420" prefWidth="560" />

        <!-- 🔥 Botón centrado -->
        <Button fx:id="closeButton" layoutX="200.0" layoutY="445.0" onAction="#onClose" prefHeight="45" prefWidth="200" styleClass="button-danger" text="Cerrar" />

    </children>

</AnchorPane>
