<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="root"
            prefHeight="920.0"
            prefWidth="1400.0"
            stylesheets="@../../styles/reactnative.css"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="deploy.ReactNativeController">

    <children>

        <!-- TITULO -->
        <Label layoutX="40" layoutY="30" styleClass="title-label" text="React Native Deploy"/>

        <!-- RUTA -->
        <Label layoutX="40" layoutY="90" styleClass="section-label" text="Ruta del proyecto"/>

        <TextField fx:id="projectPathField"
                   layoutX="40" layoutY="120"
                   prefHeight="45" prefWidth="535"
                   styleClass="input"/>

        <Button fx:id="saveButton"
                layoutX="40" layoutY="180"
                prefHeight="45" prefWidth="130"
                styleClass="button-save"
                text="Guardar"
                onAction="#onSave"/>

        <Button fx:id="unlockButton"
                layoutX="186" layoutY="180"
                prefHeight="45" prefWidth="150"
                styleClass="button-unlock"
                text="Desbloquear"
                onAction="#onUnlock"/>

        <Button fx:id="browseButton"
                layoutX="351" layoutY="180"
                prefHeight="45" prefWidth="230"
                styleClass="button-primary"
                text="Buscar ruta"
                onAction="#onBrowse"/>

        <Label fx:id="statusLabel"
               layoutX="40" layoutY="240"
               styleClass="status-label"
               text="Estado: -"/>

        <!-- TIPO -->
        <Label layoutX="40" layoutY="280"
               styleClass="section-label"
               text="Tipo de proyecto"/>

        <ComboBox fx:id="projectTypeCombo"
                  layoutX="40" layoutY="315"
                  prefHeight="45" prefWidth="535"/>

        <!-- SERVICIOS -->
        <Label layoutX="40" layoutY="383"
               styleClass="section-label"
               text="Servicios React Native"/>

        <!-- ========================= -->
        <!-- CLI → METRO -->
        <!-- ========================= -->
        <AnchorPane fx:id="metroBlock"
                    layoutX="40" layoutY="430"
                    prefWidth="260" prefHeight="200">

            <children>

                <Label layoutX="0" layoutY="0"
                       styleClass="card-title"
                       text="METRO"/>

                <ImageView fx:id="metroIcon"
                           layoutX="0" layoutY="40"
                           fitHeight="29" fitWidth="29">
                    <image>
                        <Image url="@../../devIcons/metro.png"/>
                    </image>
                </ImageView>

                <Button fx:id="startMetroBtn"
                        layoutX="0" layoutY="100"
                        prefWidth="110"
                        styleClass="button-success"
                        text="Arrancar"
                        onAction="#onStartMetro"/>

                <Button fx:id="stopMetroBtn"
                        layoutX="120" layoutY="100"
                        prefWidth="110"
                        styleClass="button-danger"
                        text="Parar"
                        onAction="#onStopMetro"/>

                <Label fx:id="metroStatus"
                       layoutX="0" layoutY="150"
                       styleClass="status status-off"
                       text="DETENIDO"/>

            </children>
        </AnchorPane>

        <!-- ========================= -->
        <!-- CLI → ANDROID -->
        <!-- ========================= -->
        <AnchorPane fx:id="androidBlock"
                    layoutX="351" layoutY="430"
                    prefWidth="260" prefHeight="200">

            <children>

                <Label fx:id="androidTitle"
                       layoutX="0" layoutY="0"
                       styleClass="card-title"
                       text="ANDROID"/>

                <ImageView fx:id="androidIcon"
                           layoutX="0" layoutY="40"
                           fitHeight="29" fitWidth="29">
                    <image>
                        <Image url="@../../devIcons/android.png"/>
                    </image>
                </ImageView>

                <Button fx:id="startAndroidBtn"
                        layoutX="0" layoutY="100"
                        prefWidth="110"
                        styleClass="button-success"
                        text="Arrancar"
                        onAction="#onStartAndroid"/>

                <Button fx:id="stopAndroidBtn"
                        layoutX="120" layoutY="100"
                        prefWidth="110"
                        styleClass="button-danger"
                        text="Parar"
                        onAction="#onStopAndroid"/>

                <Label fx:id="androidStatus"
                       layoutX="0" layoutY="150"
                       styleClass="status status-off"
                       text="DETENIDO"/>

            </children>
        </AnchorPane>

        <!-- ========================= -->
        <!-- 🔥 EXPO BLOQUE COMBINADO -->
        <!-- ========================= -->
        <AnchorPane fx:id="expoBlock"
                    layoutX="40" layoutY="430"
                    prefWidth="571" prefHeight="200"
                    visible="false"
                    managed="false">

            <children>

                <Label layoutX="0" layoutY="0"
                       styleClass="card-title"
                       text="EXPO (METRO + ANDROID)"/>

                <!-- ICONOS JUNTOS -->
                <ImageView layoutX="0" layoutY="40"
                           fitHeight="29" fitWidth="29">
                    <image>
                        <Image url="@../../devIcons/metro.png"/>
                    </image>
                </ImageView>

                <ImageView layoutX="40" layoutY="40"
                           fitHeight="29" fitWidth="29">
                    <image>
                        <Image url="@../../devIcons/android.png"/>
                    </image>
                </ImageView>

                <Button layoutX="0" layoutY="100"
                        prefWidth="110"
                        styleClass="button-success"
                        text="Arrancar"
                        onAction="#onStartAndroid"/>

                <Button layoutX="120" layoutY="100"
                        prefWidth="110"
                        styleClass="button-danger"
                        text="Parar"
                        onAction="#onStopAndroid"/>

                <Label layoutX="0" layoutY="150"
                       styleClass="status status-off"
                       text="AUTO"/>

            </children>
        </AnchorPane>

        <!-- BUILD -->
        <Label layoutX="40" layoutY="665"
               styleClass="section-label"
               text="Construye la aplicacion desde aquí"/>

        <Button fx:id="buildAPKButton"
                layoutX="35" layoutY="693"
                prefHeight="45" prefWidth="250"
                styleClass="button-primary"
                text="Opciones Avanzadas"
                onAction="#onOpenBuildAPK"/>

        <!-- LOG -->
        <Label layoutX="650" layoutY="76"
               styleClass="title-log"
               text="Log de ejecución"/>

        <Button layoutX="650" layoutY="120"
                prefHeight="40" prefWidth="120"
                styleClass="button-primary"
                text="Copiar"
                onAction="#onCopyLog"/>

        <Button layoutX="790" layoutY="120"
                prefHeight="40" prefWidth="120"
                styleClass="button-secondary"
                text="Limpiar"
                onAction="#onClearLog"/>

        <TextArea fx:id="logArea"
                  layoutX="650" layoutY="180"
                  prefHeight="600" prefWidth="700"
                  editable="false"
                  wrapText="true"
                  styleClass="console"/>

        <!-- FOOTER -->
        <Separator layoutX="40" layoutY="830" prefWidth="1320"/>

        <Button layoutX="620" layoutY="850"
                prefHeight="45" prefWidth="160"
                styleClass="button-danger"
                text="Cerrar"
                onAction="#onClose"/>

    </children>
</AnchorPane>