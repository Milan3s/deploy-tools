<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="root"
            prefHeight="864.0"
            prefWidth="1148.0"
            stylesheets="@../styles/npminstall.css"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="npminstall.NpminstallController">

    <children>

        <!-- ================= HEADER ================= -->

        <Label layoutX="40" layoutY="30"
               styleClass="titulo-principal"
               text="Gestión de dependencias (NPM)" />

        <Separator layoutX="40" layoutY="65" prefWidth="1060" />

        <Label layoutX="40" layoutY="80" prefWidth="900"
               styleClass="descripcion"
               text="Instala, lista, elimina y actualiza dependencias del proyecto."
               wrapText="true" />

        <!-- ================= RUTA ================= -->

        <Label layoutX="40" layoutY="130"
               styleClass="label-form"
               text="Ruta del proyecto" />

        <TextField fx:id="projectPathField"
                   layoutX="40" layoutY="160"
                   prefWidth="420"
                   styleClass="input" />

        <Button fx:id="browseProjectButton"
                layoutX="480" layoutY="160"
                onAction="#buscarProyecto"
                styleClass="boton-build"
                text="Buscar" />

        <Button fx:id="savePathButton"
                layoutX="40" layoutY="200"
                onAction="#guardarRutaProyecto"
                prefWidth="180"
                styleClass="boton-success"
                text="Guardar y bloquear" />

        <Button fx:id="unlockPathButton"
                layoutX="240" layoutY="200"
                onAction="#desbloquearRuta"
                prefWidth="180"
                styleClass="boton-warning"
                text="Desbloquear ruta" />

        <!-- ================= PACKAGE ================= -->

        <Label layoutX="40" layoutY="260"
               styleClass="label-form"
               text="Gestor de paquetes" />

        <ComboBox fx:id="packageManagerCombo"
                  layoutX="40" layoutY="290"
                  prefWidth="200"
                  styleClass="combo-box" />

        <!-- ================= INSTALAR ================= -->

        <Label layoutX="40" layoutY="340"
               styleClass="label-form"
               text="Instalar dependencia" />

        <TextField fx:id="parameterField"
                   layoutX="40" layoutY="370"
                   prefWidth="420"
                   promptText="Ej: axios | react-router"
                   styleClass="input" />

        <Button fx:id="installButton"
                layoutX="40" layoutY="410"
                onAction="#instalarDependencias"
                prefWidth="160"
                styleClass="boton-build"
                text="Instalar" />

        <Button fx:id="listDependenciesButton"
                layoutX="220" layoutY="410"
                onAction="#listarDependencias"
                prefWidth="200"
                styleClass="boton-secundario"
                text="Listar dependencias" />

        <!-- ================= ELIMINAR ================= -->

        <Label layoutX="40" layoutY="470"
               styleClass="label-form"
               text="Eliminar dependencia" />

        <TextField fx:id="removeField"
                   layoutX="40" layoutY="500"
                   prefWidth="420"
                   promptText="Ej: axios"
                   styleClass="input" />

        <Button fx:id="removeButton"
                layoutX="40" layoutY="540"
                onAction="#eliminarDependencia"
                prefWidth="160"
                styleClass="boton-danger"
                text="Eliminar" />

        <!-- ================= ACTUALIZAR ================= -->

        <Label layoutX="40" layoutY="600"
               styleClass="label-form"
               text="Actualizar dependencia" />

        <TextField fx:id="updateField"
                   layoutX="40" layoutY="630"
                   prefWidth="420"
                   promptText="Ej: axios"
                   styleClass="input" />

        <Button fx:id="updateButton"
                layoutX="40" layoutY="670"
                onAction="#actualizarDependencia"
                prefWidth="160"
                styleClass="boton-build"
                text="Actualizar" />

        <!-- ================= ESTADO ================= -->

        <Label layoutX="40" layoutY="730"
               styleClass="label-estado-titulo"
               text="Estado proceso:" />

        <Label fx:id="processStatusLabel"
               layoutX="160" layoutY="730"
               styleClass="estado-warning"
               text="No iniciado" />

        <!-- ================= CONSOLA ================= -->

        <Label layoutX="620" layoutY="130"
               styleClass="titulo-consola"
               text="Consola" />

        <Button fx:id="copyConsoleButton"
                layoutX="620" layoutY="160"
                onAction="#copiarLogs"
                styleClass="boton-secundario"
                text="Copiar" />

        <Button fx:id="clearConsoleButton"
                layoutX="700" layoutY="160"
                onAction="#limpiarLogs"
                styleClass="boton-secundario"
                text="Limpiar" />

        <TextArea fx:id="console"
                  layoutX="620" layoutY="200"
                  prefHeight="520"
                  prefWidth="480"
                  editable="false"
                  styleClass="consola" />

        <!-- ================= FOOTER ================= -->

        <!-- 🔥 Separador bien alineado -->
        <Separator layoutX="40" layoutY="760" prefWidth="1060" />

        <!-- 🔥 Botón centrado real -->
        <Button fx:id="btnCerrar"
                layoutX="514" layoutY="790"
                onAction="#actionBtnCerrar"
                prefWidth="120"
                prefHeight="40"
                styleClass="boton-danger"
                text="Cerrar" />

    </children>

</AnchorPane>