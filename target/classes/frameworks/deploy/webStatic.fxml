<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="1000.0" prefWidth="1400.0"
            stylesheets="@../../styles/webstatic.css"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="processDeploy.WebStaticController">

    <children>

        <!-- HEADER -->
        <Label layoutX="30" layoutY="25"
               styleClass="title-label"
               text="Servicios Web (Frontend / Backend)" />

        <Label layoutX="30" layoutY="60"
               styleClass="status-label"
               text="Gestiona el arranque y parada de servicios web" />

        <!-- CONFIGURACIÓN -->
        <Label layoutX="30" layoutY="110"
               styleClass="section-label"
               text="Configuración" />

        <Button fx:id="configButton"
                layoutX="30" layoutY="140"
                prefHeight="45" prefWidth="300"
                styleClass="button-primary"
                onAction="#onOpenConfig"
                text="Abrir configuración global" />

        <Label fx:id="configStatusLabel"
               layoutX="30" layoutY="195"
               prefWidth="300"
               styleClass="status-info"
               text="Sin configurar" />

        <!-- BACKEND -->
        <Label layoutX="30" layoutY="240" styleClass="section-label" text="Backend" />

        <TextField fx:id="backendPathField"
                   layoutX="30" layoutY="270"
                   prefHeight="45" prefWidth="300"
                   styleClass="text-field"
                   promptText="Ruta del backend" />

        <ComboBox fx:id="backendTypeCombo"
                  layoutX="30" layoutY="330"
                  prefHeight="45" prefWidth="300"
                  styleClass="combo-box"
                  promptText="Tipo de backend" />

        <TextField fx:id="backendCommandField"
                   layoutX="30" layoutY="390"
                   prefHeight="45" prefWidth="300"
                   styleClass="text-field"
                   promptText="Comando personalizado (opcional)" />

        <Button fx:id="backendStartBtn"
                layoutX="30" layoutY="450"
                prefHeight="45" prefWidth="95"
                styleClass="button-create"
                onAction="#onStartBackend"
                text="Arrancar" />

        <Button fx:id="backendStopBtn"
                layoutX="135" layoutY="450"
                prefHeight="45" prefWidth="95"
                styleClass="button-clear"
                onAction="#onStopBackend"
                text="Detener" />

        <Button fx:id="backendBuildBtn"
                layoutX="240" layoutY="450"
                prefHeight="45" prefWidth="90"
                styleClass="button-primary"
                onAction="#onBuildBackend"
                text="Construir" />

        <Button fx:id="backendBrowserBtn"
                layoutX="30" layoutY="510"
                prefHeight="45" prefWidth="300"
                styleClass="button-browser"
                onAction="#onOpenBackendBrowser"
                text="Abrir en navegador" />

        <!-- FRONTEND -->
        <Label layoutX="30" layoutY="580" styleClass="section-label" text="Frontend" />

        <TextField fx:id="frontendPathField"
                   layoutX="30" layoutY="610"
                   prefHeight="45" prefWidth="300"
                   styleClass="text-field"
                   promptText="Ruta del frontend" />

        <ComboBox fx:id="frontendTypeCombo"
                  layoutX="30" layoutY="670"
                  prefHeight="45" prefWidth="300"
                  styleClass="combo-box"
                  promptText="Tipo de frontend" />

        <TextField fx:id="frontendCommandField"
                   layoutX="30" layoutY="730"
                   prefHeight="45" prefWidth="300"
                   styleClass="text-field"
                   promptText="Comando personalizado (opcional)" />

        <Button fx:id="frontendStartBtn"
                layoutX="30" layoutY="790"
                prefHeight="45" prefWidth="95"
                styleClass="button-create"
                onAction="#onStartFrontend"
                text="Arrancar" />

        <Button fx:id="frontendStopBtn"
                layoutX="135" layoutY="790"
                prefHeight="45" prefWidth="95"
                styleClass="button-clear"
                onAction="#onStopFrontend"
                text="Detener" />

        <Button fx:id="frontendBuildBtn"
                layoutX="240" layoutY="790"
                prefHeight="45" prefWidth="90"
                styleClass="button-primary"
                onAction="#onBuildFrontend"
                text="Construir" />

        <Button fx:id="frontendBrowserBtn"
                layoutX="30" layoutY="850"
                prefHeight="45" prefWidth="300"
                styleClass="button-browser"
                onAction="#onOpenFrontendBrowser"
                text="Abrir en navegador" />

        <!-- LOG BACKEND -->
        <Label layoutX="380" layoutY="110" styleClass="section-label" text="Registro Backend" />

        <Button fx:id="backendCopyBtn"
                layoutX="380" layoutY="140"
                prefHeight="35" prefWidth="100"
                styleClass="button-primary"
                onAction="#onCopyBackendLog"
                text="Copiar" />

        <Button fx:id="backendClearBtn"
                layoutX="490" layoutY="140"
                prefHeight="35" prefWidth="120"
                styleClass="button-primary"
                onAction="#onClearBackendLog"
                text="Limpiar" />

        <TextArea fx:id="backendLogArea"
                  layoutX="380" layoutY="185"
                  prefHeight="300" prefWidth="950"
                  editable="false"
                  wrapText="true"
                  styleClass="text-area" />

        <!-- LOG FRONTEND -->
        <Label layoutX="380" layoutY="510" styleClass="section-label" text="Registro Frontend" />

        <Button fx:id="frontendCopyBtn"
                layoutX="380" layoutY="540"
                prefHeight="35" prefWidth="100"
                styleClass="button-primary"
                onAction="#onCopyFrontendLog"
                text="Copiar" />

        <Button fx:id="frontendClearBtn"
                layoutX="490" layoutY="540"
                prefHeight="35" prefWidth="120"
                styleClass="button-primary"
                onAction="#onClearFrontendLog"
                text="Limpiar" />

        <TextArea fx:id="frontendLogArea"
                  layoutX="380" layoutY="585"
                  prefHeight="300" prefWidth="950"
                  editable="false"
                  wrapText="true"
                  styleClass="text-area" />

        <!-- ================= FOOTER ================= -->

        <!-- 🔥 Separator -->
        <Separator layoutX="30"
                   layoutY="910"
                   prefWidth="1340" />

        <!-- 🔥 Botón centrado -->
        <Button fx:id="closeButton"
                layoutX="640"
                layoutY="935"
                prefHeight="40"
                prefWidth="140"
                styleClass="button-clear"
                onAction="#onCloseWindow"
                text="Cerrar ventana" />

    </children>
</AnchorPane>