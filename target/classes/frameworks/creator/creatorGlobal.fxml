<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="creatorRoot" prefHeight="919.0" prefWidth="1200" stylesheets="@../../styles/creatorglobal.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="creator.CreatorGlobalController">

    <children>

        <Label layoutX="30" layoutY="25" styleClass="title-label" text="Creador de Proyectos Web" />

        <Label layoutX="30" layoutY="55" styleClass="status-label" text="Crea proyectos usando comandos predefinidos (React, Laravel, etc.)" />


        <Label layoutX="30" layoutY="110" styleClass="section-label" text="Configuración global del proyecto" />

        <Button fx:id="configButton" layoutX="30" layoutY="140" onAction="#onOpenConfig" prefHeight="45" prefWidth="300" styleClass="button-primary" text="Abrir configuración global" />

        <Label fx:id="configStatusLabel" layoutX="30" layoutY="195" styleClass="status-info" text="Sin configurar" />


        <Label layoutX="30" layoutY="240" styleClass="section-label" text="Ruta base de proyectos" />

        <TextField fx:id="basePathField" layoutX="30" layoutY="270" prefHeight="45" prefWidth="300" promptText="C:/projects" styleClass="text-field" />

        <Button layoutX="30" layoutY="330" onAction="#onBrowseBasePath" prefHeight="45" prefWidth="140" styleClass="button-search" text="Buscar" />

        <Button layoutX="190" layoutY="330" onAction="#onSaveBasePath" prefHeight="45" prefWidth="140" styleClass="button-save" text="Guardar ruta" />


        <Label layoutX="30" layoutY="400" styleClass="section-label" text="Tecnología" />

        <ComboBox fx:id="frameworkCombo" layoutX="30" layoutY="430" prefHeight="45" prefWidth="300" promptText="Selecciona tecnología" />


        <Label layoutX="30" layoutY="490" styleClass="section-label" text="Versión" />

        <ComboBox fx:id="versionCombo" layoutX="30" layoutY="520" prefHeight="45" prefWidth="300" promptText="Selecciona versión" />


        <Label layoutX="30" layoutY="580" styleClass="section-label" text="Nombre del proyecto" />

        <TextField fx:id="projectNameField" layoutX="30" layoutY="610" prefHeight="45" prefWidth="300" promptText="mi-proyecto" styleClass="text-field" />


        <Button layoutX="30" layoutY="680" onAction="#onRunCommand" prefHeight="45" prefWidth="140" styleClass="button-create" text="Crear proyecto" />

        <Button layoutX="190" layoutY="680" onAction="#onClearFields" prefHeight="45" prefWidth="140" styleClass="button-clear" text="Limpiar" />


        <Label layoutX="400" layoutY="110" styleClass="section-label" text="Console log" />

        <Button layoutX="400" layoutY="140" onAction="#onCopyLog" prefHeight="35" prefWidth="110" styleClass="button-primary" text="Copiar" />

        <Button layoutX="520" layoutY="140" onAction="#onClearLog" prefHeight="35" prefWidth="130" styleClass="button-primary" text="Limpiar log" />

        <TextArea fx:id="logArea" editable="false" layoutX="400" layoutY="190" prefHeight="620" prefWidth="760" styleClass="text-area" wrapText="true" />

        <!-- ================= FOOTER ================= -->

        <Separator layoutX="20" layoutY="830" prefWidth="1160" />

        <Button fx:id="closeBtn" layoutX="490" layoutY="850" onAction="#onClose" prefHeight="40" prefWidth="220" styleClass="button-secondary" text="Cerrar" />

    </children>
</AnchorPane>
